---
network:
  version: {{ config.network_version.value }}
  config:
    {%- for iface in config.interfaces %}
    - type: physical
      name: {{ iface.name }}
      {%- if iface.macaddress %}
      # Match the NIC by MAC (lvlab pins one per interface), not by the
      # ``name`` label: the guest device is enp1s0/ens3/eth0 depending on
      # the distro, so a name-only match silently fails to apply the
      # static config when the device isn't literally ``eth0`` (Debian 11
      # cloud images use enp1s0). cloud-init's v1 renderer binds the
      # config to the device carrying this MAC.
      mac_address: {{ iface.macaddress }}
      {%- endif %}
      subnets:
         {%- if iface.ip4 %}
         - type: static
           address: {{ iface.ip4 }}
           gateway: {{ iface.ip4gw }}
         {%- endif %}
         {%- if iface.ip6 %}
         # static6 is cloud-init's ENI shape for a per-family IPv6 static
         # assignment alongside (or instead of) the v4 ``static`` subnet
         # above (#137).
         - type: static6
           address: {{ iface.ip6 }}
           gateway: {{ iface.ip6gw }}
         {%- endif %}
         {%- if not iface.ip4 and not iface.ip6 %}
         - type: dhcp4
         {%- endif %}
    {%- if config.nameservers.search is defined and config.nameservers.search | length > 0 %}
    - type: nameserver
      address:
        {%- for dns_server in config.nameservers.addresses %}
        - {{ dns_server }}
        {%- endfor %}
      search:
        {%- for search_domain in config.nameservers.search %}
        - {{ search_domain }}
        {%- endfor %}
    {%- endif %}
    {%- endfor %}

{# Ensure newline at end of rendered file #}
