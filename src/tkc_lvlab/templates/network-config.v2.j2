---
# cloud-init network-config v2 (netplan).
#
# The ``match.driver: virtio_net`` block decouples the manifest's
# ``iface.name`` from the kernel-assigned device name. Every NIC
# lvlab deploys uses ``model=virtio`` (see _virt_install_network_arg
# in src/tkc_lvlab/utils/libvirt.py), so virtio_net matches
# regardless of whether the cloud image keeps systemd predictable
# naming on (debian/fedora → enp1s0) or disables it (almalinux10's
# cloud cmdline → eth0).
#
# ``set-name`` renames the matched NIC to whatever ``iface.name`` is
# in the manifest, so the in-guest device name is operator-chosen
# rather than distro-chosen.
#
# Multi-NIC caveat: netplan ``set-name`` works reliably only when
# the match resolves to a single device. For >1 virtio NIC, the
# manifest needs a per-interface MAC match instead of driver match —
# not supported by this template today.
network:
  version: {{ config.network_version.value }}
  ethernets:
    {%- for iface in config.interfaces %}
    {{ iface.name }}:
      match:
        driver: virtio_net
      set-name: {{ iface.name }}
      {%- if iface.ip4 %}
      dhcp4: false
      dhcp6: false
      {%- else %}
      dhcp4: true
      dhcp6: true
      {%- endif %}
      {%- if iface.ip4 %}
      addresses:
        - {{ iface.ip4 }}
      {%- set ns_addresses = config.nameservers.addresses if config.nameservers.addresses is defined else [] %}
      {%- set ns_search = config.nameservers.search if config.nameservers.search is defined else [] %}
      {%- if ns_addresses | length > 0 or ns_search | length > 0 %}
      nameservers:
        {%- if ns_addresses | length > 0 %}
        addresses:
          {%- for dns_server in ns_addresses %}
          - {{ dns_server }}
          {%- endfor %}
        {%- endif %}
        {%- if ns_search | length > 0 %}
        search:
          {%- for search_domain in ns_search %}
          - {{ search_domain }}
          {%- endfor %}
        {%- endif %}
      {%- endif %}
      routes:
        - to: 0.0.0.0/0
          via: {{ iface.ip4gw }}
      {%- endif %}
   {%- endfor %}

{# Ensure newline at end of rendered file #}
