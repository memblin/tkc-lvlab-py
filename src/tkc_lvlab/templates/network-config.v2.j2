---
# cloud-init network-config v2 (netplan).
#
# Each NIC is selected by ``match.macaddress`` â€” lvlab pins a deterministic
# MAC per interface (see generate_mac in src/tkc_lvlab/utils/network.py) and
# passes the same address to both ``virt-install --network ...,mac=`` and
# this config â€” and configured under whatever name the distro assigns it
# (enp1s0 / ens3 / eth0).
#
# MAC matching is the only selector cloud-init honours across BOTH of its
# renderers. cloud-init translates this v2 doc to the distro's native
# format: a verbatim netplan file on Debian/Ubuntu (systemd-networkd) but
# a NetworkManager keyfile on Fedora/RHEL. The NM renderer does NOT honour
# ``match: driver`` â€” it reduces the netplan stanza key to a literal
# ``interface-name``, so a driver match silently binds only when the guest
# NIC happens to be named like the label (``eth0``). It got that wrong on
# Fedora (NIC is ``enp1s0``) and the static profile never bound, falling
# back to NM's default DHCP. ``match: macaddress`` becomes a MAC-bound
# keyfile that activates regardless of device name. ``match: driver`` is
# kept only as a fallback for the (now unexpected) MAC-less interface.
#
# We deliberately do NOT ``set-name`` the interface. Renaming via netplan
# works under NetworkManager (Fedora) but leaves the NIC unconfigured
# under systemd-networkd (Debian/Ubuntu), so the guest never completes
# DHCP. The ``iface.name`` below is therefore only a netplan label, not
# the in-guest device name.
#
# Per-interface MAC matching also disambiguates multiple NICs (the old
# driver match could not), though multi-NIC manifests are not yet exercised
# end-to-end.
#
# IPv6 (#137): when ``iface.ip6`` is set, the stanza emits a second
# ``addresses`` entry and a ``::/0`` route via ``iface.ip6gw``. netplan
# accepts mixed-family addresses and per-family routes â€” dual-stack
# guests get both. ``dhcp4``/``dhcp6`` are switched off only for the
# families that have a static address, so a v4-only manifest can still
# accept SLAAC/DHCPv6 and a v6-only manifest can still accept DHCPv4.
network:
  version: {{ config.network_version.value }}
  ethernets:
    {%- for iface in config.interfaces %}
    {{ iface.name }}:
      match:
      {%- if iface.macaddress %}
        # Quoted: an all-numeric MAC (every octet <= 0x3b) would otherwise
        # be misparsed as a YAML 1.1 base-60 integer by cloud-init's loader.
        macaddress: "{{ iface.macaddress }}"
      {%- else %}
        driver: virtio_net
      {%- endif %}
      {%- if iface.ip4 %}
      dhcp4: false
      {%- else %}
      dhcp4: true
      {%- endif %}
      {%- if iface.ip4 or iface.ip6 %}
      # dhcp6 is turned off when EITHER family has a static address. The
      # historical v4-only behaviour (always disabling dhcp6 on a static
      # interface) is preserved as a defensive measure â€” netplan's DHCPv6
      # client hangs on some distros, and operators on v4-only manifests
      # have never opted into SLAAC/DHCPv6 implicitly.
      dhcp6: false
      {%- else %}
      dhcp6: true
      {%- endif %}
      {%- if iface.ip4 or iface.ip6 %}
      addresses:
        {%- if iface.ip4 %}
        - {{ iface.ip4 }}
        {%- endif %}
        {%- if iface.ip6 %}
        - {{ iface.ip6 }}
        {%- endif %}
      {%- set ns_addresses = config.nameservers.addresses if config.nameservers.addresses is defined else [] %}
      {%- set ns_search = config.nameservers.search if config.nameservers.search is defined else [] %}
      {%- if ns_addresses | length > 0 or ns_search | length > 0 %}
      nameservers:
        {%- if ns_addresses | length > 0 %}
        addresses:
          {%- for dns_server in ns_addresses %}
          - {{ dns_server }}
          {%- endfor %}
        {%- endif %}
        {%- if ns_search | length > 0 %}
        search:
          {%- for search_domain in ns_search %}
          - {{ search_domain }}
          {%- endfor %}
        {%- endif %}
      {%- endif %}
      routes:
        {%- if iface.ip4 %}
        - to: 0.0.0.0/0
          via: {{ iface.ip4gw }}
        {%- endif %}
        {%- if iface.ip6 %}
        - to: ::/0
          via: {{ iface.ip6gw }}
        {%- endif %}
      {%- endif %}
   {%- endfor %}

{# Ensure newline at end of rendered file #}
